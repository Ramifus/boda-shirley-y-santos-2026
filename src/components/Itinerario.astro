---
// Itinerario.astro
---

<section class="py-4 lg:py-10 px-4 relative overflow-hidden">
  <!-- Fondo sutil con textura -->
  <div class="absolute inset-0 bg-gradient-to-b from-[#fffaf5]/40 via-[#fff9f0]/20 to-[#fffaf5]/40 z-0"></div>

  <div class="max-w-5xl mx-auto relative z-10">

    <div class="max-w-3xl mx-auto relative">

      <!-- 🍃 HOJA IZQUIERDA 1 - arriba (~20%) -->
      <div class="absolute left-0 top-[20%] -translate-y-1/2 w-12 pointer-events-none -ml-6 sm:-ml-7 md:-ml-8 z-20" id="hoja-itinerario-izq">
        <img
          src="/imagenes/Hojas.webp"
          alt="Hoja izquierda"
          class="w-full h-auto object-contain transform -scale-x-100"
        />
      </div>

      <!-- 🍃 HOJA DERECHA 1 - un poco más abajo (~40%) -->
      <div class="absolute right-0 top-[40%] -translate-y-1/2 w-12 pointer-events-none -mr-6 sm:-mr-7 md:-mr-8 z-20" id="hoja-itinerario-der">
        <img
          src="/imagenes/Hojas.webp"
          alt="Hoja derecha"
          class="w-full h-auto object-contain"
        />
      </div>

      <!-- 🍃 HOJA IZQUIERDA 2 - más abajo (~60%) -->
      <div class="absolute left-0 top-[60%] -translate-y-1/2 w-12 pointer-events-none -ml-6 sm:-ml-7 md:-ml-8 z-20" id="hoja-itinerario-izq2">
        <img
          src="/imagenes/Hojas.webp"
          alt="Hoja izquierda"
          class="w-full h-auto object-contain transform -scale-x-100"
        />
      </div>

      <!-- 🍃 HOJA DERECHA 2 - al final (~80%) -->
      <div class="absolute right-0 top-[80%] -translate-y-1/2 w-12 pointer-events-none -mr-6 sm:-mr-7 md:-mr-8 z-20" id="hoja-itinerario-der2">
        <img
          src="/imagenes/Hojas.webp"
          alt="Hoja derecha"
          class="w-full h-auto object-contain"
        />
      </div>

      <!-- 🌸 FLORES DECORATIVAS ARRIBA -->
      <div class="flex justify-center mb-4" id="flores-itinerario">
        <img
          src="/imagenes/Separadores.webp"
          alt="Flores decorativas"
          class="w-32 md:w-40 lg:w-48 h-auto opacity-90"
        />
      </div>

      <!-- TÍTULO -->
      <div class="text-center mb-4" id="titulo-itinerario">
        <h2 class="font-charm text-2xl md:text-3xl lg:text-3xl text-[#C9A961] font-bold mb-4">
          ITINERARIO
        </h2>
        <!-- Línea decorativa -->
        <div class="flex items-center justify-center gap-3">
          <div class="w-16 h-[2px] bg-gradient-to-r from-transparent to-[#C9A961]"></div>
          <div class="w-2 h-2 rounded-full bg-[#C9A961]"></div>
          <div class="w-16 h-[2px] bg-gradient-to-l from-transparent to-[#C9A961]"></div>
        </div>
      </div>

      <!-- TIMELINE CONTAINER -->
      <div class="relative px-4 md:px-8">
        
        <!-- Línea vertical CENTRAL con degradado mejorado -->
        <div class="absolute left-1/2 -translate-x-1/2 top-0 bottom-0 w-[3px] bg-gradient-to-b from-[#C9A961] via-[#d4b16e] to-[#C9A961] rounded-full shadow-sm" id="linea-central"></div>

        <!-- EVENTOS DEL ITINERARIO -->
        <div class="space-y-0" id="eventos-container">

          <!-- ❤️ CORAZÓN 1 -->
          <div class="flex justify-center py-1">
            <div class="w-8 h-8 rounded-full bg-[#C9A961] flex items-center justify-center relative z-10 corazon-item shadow-md">
              <svg class="w-4 h-4 text-white" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
              </svg>
            </div>
          </div>

          <!-- EVENTO 1: Misa Religiosa (IMAGEN IZQ - TEXTO DER) -->
          <div class="evento-item grid grid-cols-2 gap-6 md:gap-10 py-1">
            <!-- IMAGEN IZQUIERDA -->
            <div class="flex flex-col items-center justify-center px-3 md:px-6 imagen-izq">
              <div class="w-16 h-16 md:w-20 md:h-20 lg:w-24 lg:h-24 transform transition-transform duration-300 hover:scale-110">
                <img src="/imagenes/iglesia.png" alt="Ceremonia" class="w-full h-full object-contain drop-shadow-md icono-dorado" />
              </div>
            </div>
            <!-- TEXTO DERECHA -->
            <div class="flex flex-col items-center justify-center px-3 md:px-6 text-center texto-der">
              <p class="font-charm text-xl md:text-base lg:text-lg text-[#626a54] font-bold leading-tight">Misa religiosa</p>
              <p class="font-charm text-xl md:text-sm text-[#626a54] mt-1">15:00 Hrs</p>
            </div>
          </div>

          <!-- ❤️ CORAZÓN 2 -->
          <div class="flex justify-center py-1">
            <div class="w-8 h-8 rounded-full bg-[#C9A961] flex items-center justify-center relative z-10 corazon-item shadow-md">
              <svg class="w-4 h-4 text-white" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
              </svg>
            </div>
          </div>

          <!-- EVENTO 2: Recepción (TEXTO IZQ - IMAGEN DER) -->
          <div class="evento-item grid grid-cols-2 gap-6 md:gap-10 py-1">
            <!-- TEXTO IZQUIERDA -->
            <div class="flex flex-col items-center justify-center px-3 md:px-6 text-center texto-izq">
              <p class="font-charm text-xl md:text-base lg:text-lg text-[#626a54] font-bold leading-tight">Recepción</p>
              <p class="font-charm text-xl md:text-sm text-[#626a54] mt-1">17:30 Hrs</p>
            </div>
            <!-- IMAGEN DERECHA -->
            <div class="flex flex-col items-center justify-center px-3 md:px-6 imagen-der">
              <div class="w-16 h-16 md:w-20 md:h-20 lg:w-24 lg:h-24 transform transition-transform duration-300 hover:scale-110">
                <img src="/imagenes/recepcion.png" alt="Boda Civil" class="w-full h-full object-contain drop-shadow-md icono-dorado" />
              </div>
            </div>
          </div>

          <!-- ❤️ CORAZÓN 3 -->
          <div class="flex justify-center py-1">
            <div class="w-8 h-8 rounded-full bg-[#C9A961] flex items-center justify-center relative z-10 corazon-item shadow-md">
              <svg class="w-4 h-4 text-white" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
              </svg>
            </div>
          </div>

          <!-- EVENTO 3: Cena (IMAGEN IZQ - TEXTO DER) -->
          <div class="evento-item grid grid-cols-2 gap-6 md:gap-10 py-1">
            <!-- IMAGEN IZQUIERDA -->
            <div class="flex flex-col items-center justify-center px-3 md:px-6 imagen-izq">
              <div class="w-16 h-16 md:w-20 md:h-20 lg:w-24 lg:h-24 transform transition-transform duration-300 hover:scale-110">
                <img src="/imagenes/cena.png" alt="Cena" class="w-full h-full object-contain drop-shadow-md icono-dorado" />
              </div>
            </div>
            <!-- TEXTO DERECHA -->
            <div class="flex flex-col items-center justify-center px-3 md:px-6 text-center texto-der">
              <p class="font-charm text-xl md:text-base lg:text-lg text-[#626a54] font-bold leading-tight">Cena</p>
              <p class="font-charm text-xl md:text-sm text-[#626a54] mt-1">19:00 Hrs</p>
            </div>
          </div>

          <!-- ❤️ CORAZÓN 4 -->
          <div class="flex justify-center py-1">
            <div class="w-8 h-8 rounded-full bg-[#C9A961] flex items-center justify-center relative z-10 corazon-item shadow-md">
              <svg class="w-4 h-4 text-white" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
              </svg>
            </div>
          </div>

          <!-- EVENTO 4: Fiesta (TEXTO IZQ - IMAGEN DER) -->
          <div class="evento-item grid grid-cols-2 gap-6 md:gap-10 py-1">
            <!-- TEXTO IZQUIERDA -->
            <div class="flex flex-col items-center justify-center px-3 md:px-6 text-center texto-izq">
              <p class="font-charm text-xl md:text-base lg:text-lg text-[#626a54] font-bold leading-tight">Fiesta</p>
              <p class="font-charm text-xl md:text-sm text-[#626a54] mt-1">20:00 Hrs</p>
            </div>
            <!-- IMAGEN DERECHA -->
            <div class="flex flex-col items-center justify-center px-3 md:px-6 imagen-der">
              <div class="w-16 h-16 md:w-20 md:h-20 lg:w-24 lg:h-24 transform transition-transform duration-300 hover:scale-110">
                <img src="/imagenes/musica.png" alt="Fiesta" class="w-full h-full object-contain drop-shadow-md icono-dorado" />
              </div>
            </div>
          </div>

          <!-- ❤️ CORAZÓN 5 -->
          <div class="flex justify-center py-1">
            <div class="w-8 h-8 rounded-full bg-[#C9A961] flex items-center justify-center relative z-10 corazon-item shadow-md">
              <svg class="w-4 h-4 text-white" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
              </svg>
            </div>
          </div>

          <!-- EVENTO 5: Fin de la fiesta (IMAGEN IZQ - TEXTO DER) -->
          <div class="evento-item grid grid-cols-2 gap-6 md:gap-10 py-1">
            <!-- IMAGEN IZQUIERDA -->
            <div class="flex flex-col items-center justify-center px-3 md:px-6 imagen-izq">
              <div class="w-16 h-16 md:w-20 md:h-20 lg:w-24 lg:h-24 transform transition-transform duration-300 hover:scale-110">
                <img src="/imagenes/despedida.png" alt="Fin de fiesta" class="w-full h-full object-contain drop-shadow-md icono-dorado" />
              </div>
            </div>
            <!-- TEXTO DERECHA -->
            <div class="flex flex-col items-center justify-center px-3 md:px-6 text-center texto-der">
              <p class="font-charm text-xl md:text-base lg:text-lg text-[#626a54] font-bold leading-tight">Fin de la fiesta</p>
              <p class="font-charm text-xl md:text-sm text-[#626a54] mt-1">01:00 Hrs</p>
            </div>
          </div>

          <!-- ❤️ CORAZÓN FINAL -->
          <div class="flex justify-center py-1">
            <div class="w-8 h-8 rounded-full bg-[#C9A961] flex items-center justify-center relative z-10 corazon-item shadow-md">
              <svg class="w-4 h-4 text-white" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
              </svg>
            </div>
          </div>

        </div>

      </div>

    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  if (typeof window !== 'undefined') {
    document.addEventListener("DOMContentLoaded", () => {
      console.log("📅 Iniciando itinerario con animación simultánea perfecta...");

      // 🎯 ESTADO INICIAL
      gsap.set("#flores-itinerario", { opacity: 0, y: -30, scale: 0.8 });
      gsap.set("#titulo-itinerario", { opacity: 0, y: -20 });
      gsap.set("#linea-central", { opacity: 0, scaleY: 0, transformOrigin: "top" });
      gsap.set(".corazon-item", { opacity: 0, scale: 0 });
      
      // Hojas en los bordes (zigzag)
      gsap.set("#hoja-itinerario-izq", { opacity: 0, x: -30 });
      gsap.set("#hoja-itinerario-der", { opacity: 0, x: 30 });
      gsap.set("#hoja-itinerario-izq2", { opacity: 0, x: -30 });
      gsap.set("#hoja-itinerario-der2", { opacity: 0, x: 30 });
      
      // Imágenes desde su lado
      gsap.set(".imagen-izq", { opacity: 0, x: -150, scale: 0.7 });
      gsap.set(".imagen-der", { opacity: 0, x: 150, scale: 0.7 });
      
      // Textos con deslizamiento elegante
      gsap.set(".texto-izq", { opacity: 0, x: -100 });
      gsap.set(".texto-der", { opacity: 0, x: 100 });

      // ✨ ANIMACIÓN COMPLETAMENTE SIMULTÁNEA
      ScrollTrigger.create({
        trigger: "#flores-itinerario",
        start: "top 85%",
        end: "top 20%",
        onEnter: () => {
          const tl = gsap.timeline();

          // 🌸 TODO APARECE EXACTAMENTE AL MISMO TIEMPO usando "<"
          tl.to("#flores-itinerario", {
            opacity: 1,
            y: 0,
            scale: 1,
            duration: 1.2,
            ease: "back.out(1.5)",
          })
          .to("#titulo-itinerario", {
            opacity: 1,
            y: 0,
            duration: 1,
            ease: "power2.out",
          }, "<")
          .to("#linea-central", {
            opacity: 1,
            scaleY: 1,
            duration: 1.5,
            ease: "power2.inOut",
          }, "<")
          .to(".corazon-item", {
            opacity: 1,
            scale: 1,
            duration: 1.2,
            ease: "back.out(1.5)",
          }, "<")
          // 🍃 HOJAS EN ZIGZAG - AL MISMO TIEMPO
          .to("#hoja-itinerario-izq, #hoja-itinerario-izq2", {
            opacity: 1,
            x: 0,
            duration: 1.2,
            ease: "power2.out",
          }, "<")
          .to("#hoja-itinerario-der, #hoja-itinerario-der2", {
            opacity: 1,
            x: 0,
            duration: 1.2,
            ease: "power2.out",
          }, "<")
          // 🖼️ TODAS LAS IMÁGENES IZQUIERDA - AL MISMO TIEMPO
          .to(".imagen-izq", {
            opacity: 1,
            x: 0,
            scale: 1,
            duration: 1.3,
            ease: "power3.out",
          }, "<")
          // 🖼️ TODAS LAS IMÁGENES DERECHA - AL MISMO TIEMPO
          .to(".imagen-der", {
            opacity: 1,
            x: 0,
            scale: 1,
            duration: 1.3,
            ease: "power3.out",
          }, "<")
          // ✨ TODOS LOS TEXTOS IZQUIERDA - AL MISMO TIEMPO
          .to(".texto-izq", {
            opacity: 1,
            x: 0,
            duration: 1.2,
            ease: "power2.out",
          }, "<")
          // ✨ TODOS LOS TEXTOS DERECHA - AL MISMO TIEMPO
          .to(".texto-der", {
            opacity: 1,
            x: 0,
            duration: 1.2,
            ease: "power2.out",
          }, "<");

          // 💫 Efecto de pulso sutil en corazones (después de aparecer)
          gsap.to(".corazon-item", {
            scale: 1.08,
            duration: 2,
            ease: "sine.inOut",
            yoyo: true,
            repeat: -1,
            delay: 1.5,
          });

          // 🍃 Movimiento suave de las hojas izquierda
          gsap.to("#hoja-itinerario-izq, #hoja-itinerario-izq2", {
            y: -5,
            rotation: -2,
            duration: 2.5,
            ease: "sine.inOut",
            yoyo: true,
            repeat: -1,
            delay: 1.5,
          });

          // 🍃 Movimiento suave de las hojas derecha
          gsap.to("#hoja-itinerario-der, #hoja-itinerario-der2", {
            y: -5,
            rotation: 2,
            duration: 2.5,
            ease: "sine.inOut",
            yoyo: true,
            repeat: -1,
            delay: 1.7,
          });
        },
        onLeaveBack: () => {
          // Salida simultánea
          const tl = gsap.timeline();
          
          tl.to("#flores-itinerario, #titulo-itinerario, #linea-central, .corazon-item, #hoja-itinerario-izq, #hoja-itinerario-izq2, #hoja-itinerario-der, #hoja-itinerario-der2, .imagen-izq, .imagen-der, .texto-izq, .texto-der", {
            opacity: 0,
            duration: 0.6,
            ease: "power2.in",
          })
          .to("#flores-itinerario", {
            y: -30,
            scale: 0.8,
            duration: 0.6,
          }, "<")
          .to("#titulo-itinerario", {
            y: -20,
            duration: 0.6,
          }, "<")
          .to("#linea-central", {
            scaleY: 0,
            duration: 0.6,
          }, "<")
          .to(".corazon-item", {
            scale: 0,
            duration: 0.6,
          }, "<")
          .to("#hoja-itinerario-izq, #hoja-itinerario-izq2", {
            x: -30,
            duration: 0.6,
          }, "<")
          .to("#hoja-itinerario-der, #hoja-itinerario-der2", {
            x: 30,
            duration: 0.6,
          }, "<")
          .to(".imagen-izq", {
            x: -150,
            scale: 0.7,
            duration: 0.6,
          }, "<")
          .to(".imagen-der", {
            x: 150,
            scale: 0.7,
            duration: 0.6,
          }, "<")
          .to(".texto-izq", {
            x: -100,
            duration: 0.6,
          }, "<")
          .to(".texto-der", {
            x: 100,
            duration: 0.6,
          }, "<");
        },
      });

      console.log("📅❤️✨🍃 ¡Animación con hojas en los bordes activada!");
    });
  }
</script>

<style>
  /* Transiciones suaves para hover */
  .evento-item p {
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .evento-item:hover p:first-of-type {
    color: #a88a4d;
    transform: scale(1.08);
    text-shadow: 0 2px 8px rgba(201, 169, 97, 0.3);
  }

  /* Corazones con efecto de brillo elegante */
  .corazon-item {
    filter: drop-shadow(0 4px 12px rgba(201, 169, 97, 0.5));
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .corazon-item:hover {
    transform: scale(1.2) rotate(10deg);
    filter: drop-shadow(0 8px 20px rgba(201, 169, 97, 0.7));
  }

  /* Filtro dorado para iconos PNG */
  .icono-dorado {
    filter: invert(69%) sepia(40%) saturate(502%) hue-rotate(3deg) brightness(92%) contrast(95%);
  }

  /* Animación sutil de brillo en la línea */
  #linea-central {
    box-shadow: 0 0 15px rgba(201, 169, 97, 0.3);
  }

  /* Hojas con transición suave */
  #hoja-itinerario-izq,
  #hoja-itinerario-der {
    will-change: transform;
  }
</style>