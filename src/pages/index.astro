---
// src/pages/index.astro
import Layout from "../layouts/Layout.astro";

import NombresFlores from "../components/NombresFlores.astro";
import Reproductor from "../components/Reproductor.astro";
import Dedicatoria from "../components/Dedicatoria.astro";
import Nombres from "../components/Nombres.astro";
import Fecha from "../components/Fecha.astro";
import Contador from "../components/Contador.astro";
import Calendario from "../components/Calendario.astro";
import Direccion from "../components/Direccion.astro";
import DireccionIglesia from "../components/DireccionIglesia.astro";
import Itinerario from "../components/Itinerario.astro";
import CodigoVestimenta from "../components/CodigoVestimenta.astro";
import GaleriaFotos from "../components/GaleriaFotos.astro";
import Despedida from "../components/Despedida.astro";
import FloresAbajo from "../components/FloresAbajo.astro";
import Restriccion from "../components/Restriccion.astro";
import CompartirFotos from "../components/CompartirFotos.astro";
import Pase from "../components/Pase.astro";
---

<Layout title="Boda">
    <NombresFlores />
    <Reproductor />
    <Dedicatoria />
    <Nombres />
    <Fecha />
    <Contador />
    <Calendario />
    <DireccionIglesia />
    <Direccion />
    <Itinerario />
    <Pase numeroPases={2} />
    <CodigoVestimenta />
    <Restriccion />
    <CompartirFotos />
    <GaleriaFotos />
    <Despedida />
    <FloresAbajo />
</Layout>
